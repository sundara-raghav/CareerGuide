# ─── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_SECRET_KEY=change-me-to-a-long-random-string-in-production
FLASK_DEBUG=1

# ─── Database ─────────────────────────────────────────────────────────────────
# For local dev, SQLite is used automatically if DATABASE_URL is not set.
# For production, set a PostgreSQL URL (Supabase connection string).
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
SUPABASE_JWT_SECRET=<your-jwt-secret>

# ─── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=<your-google-maps-api-key>

# ─── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=<your-sendgrid-api-key>
MAIL_DEFAULT_SENDER=no-reply@careerguide.in

# ─── SMS / WhatsApp (Twilio) ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=<your-twilio-account-sid>
TWILIO_AUTH_TOKEN=<your-twilio-auth-token>
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>

# ─── ML ───────────────────────────────────────────────────────────────────────
ML_ARTIFACTS_DIR=app/ml/artifacts
ML_MODEL_VERSION=v1

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=CareerGuide India
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,ta,hi
MAX_UPLOAD_SIZE_MB=5
RATE_LIMIT_DEFAULT=100 per hour
